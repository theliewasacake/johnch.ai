# ========== ADMIN AUTHENTICATION ==========
# Generate a bcrypt password hash: node -e "const bcrypt=require('bcrypt');bcrypt.hash('your-password',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=
# Secret for Express sessions (use a long random string)
SESSION_SECRET=change-this-to-a-random-string
# Port the server runs on (default: 3000)
PORT=3000

# ========== DOCKER DEPLOYMENT (OPTIONAL) ==========
# Only needed if deploying with Docker
# URL of the main application repo (this repo) - for Docker to pull code
REPO_URL=https://github.com/your-username/your-blog-repo.git
# URL of the private content repo (blog posts, projects, about page)
CONTENT_REPO_URL=https://github.com/your-username/your-content-repo.git
# Optional: Container name (default: blog-site)
CONTAINER_NAME=blog-site
# Optional: Deploy key for content repo (base64-encoded private key for SSH access)
# Used as fallback if file mount is not available
CONTENT_DEPLOY_KEY=
